@page
@model SmartLog.Web.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                <i class="bi bi-shield-x display-1 text-danger"></i>
                <h2 class="mt-3">Access Denied</h2>
                <p class="text-muted">You do not have permission to access this page.</p>
                @if (!string.IsNullOrEmpty(Model.AttemptedPath))
                {
                    <p class="small text-muted">
                        <code>@Model.AttemptedPath</code>
                    </p>
                }
                <a asp-page="/Index" class="btn btn-primary mt-3">
                    <i class="bi bi-house me-2"></i>Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
