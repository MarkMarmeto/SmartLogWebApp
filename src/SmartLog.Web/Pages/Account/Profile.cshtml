@page
@model SmartLog.Web.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @Model.StatusMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-person-circle me-2"></i>My Profile
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Profile Picture Section -->
                    <div class="col-md-4 text-center mb-4">
                        <div class="profile-picture-container">
                            <img src="@Model.ProfilePictureUrl" alt="Profile Picture"
                                 class="profile-picture mb-3" id="profilePicturePreview" />

                            <div class="mt-3">
                                <label for="profilePictureInput" class="btn btn-primary btn-sm">
                                    <i class="bi bi-upload me-1"></i>Upload Photo
                                </label>
                                <input type="file" id="profilePictureInput" accept="image/*"
                                       style="display: none;" onchange="uploadProfilePicture(this)" />

                                <button type="button" class="btn btn-outline-danger btn-sm"
                                        onclick="deleteProfilePicture()">
                                    <i class="bi bi-trash me-1"></i>Remove
                                </button>
                            </div>

                            <small class="text-muted d-block mt-2">
                                JPG, PNG, or GIF. Max 5MB.
                            </small>
                        </div>
                    </div>

                    <!-- Profile Information -->
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr>
                                <th style="width: 150px;"><i class="bi bi-person me-2"></i>Name:</th>
                                <td>@Model.FullName</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-at me-2"></i>Username:</th>
                                <td>@Model.Username</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-envelope me-2"></i>Email:</th>
                                <td>@Model.Email</td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-shield me-2"></i>Role:</th>
                                <td><span class="badge bg-primary">@Model.Role</span></td>
                            </tr>
                            <tr>
                                <th><i class="bi bi-check-circle me-2"></i>Status:</th>
                                <td>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                            </tr>
                        </table>

                        <div class="mt-4">
                            <a href="/Account/ChangePassword" class="btn btn-outline-primary">
                                <i class="bi bi-key me-1"></i>Change Password
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles
{
    <style>
        .profile-picture-container {
            position: relative;
        }

        .profile-picture {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #dee2e6;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .profile-picture-loading {
            opacity: 0.5;
            filter: grayscale(100%);
        }
    </style>
}

@section Scripts
{
    <script>
        async function uploadProfilePicture(input) {
            if (!input.files || !input.files[0]) {
                return;
            }

            const file = input.files[0];

            // Validate file size (5MB)
            if (file.size > 5 * 1024 * 1024) {
                alert('File size must be less than 5MB');
                return;
            }

            // Validate file type
            if (!file.type.match('image.*')) {
                alert('Please select an image file');
                return;
            }

            const formData = new FormData();
            formData.append('file', file);

            const preview = document.getElementById('profilePicturePreview');
            preview.classList.add('profile-picture-loading');

            try {
                const response = await fetch('/api/v1/profile-picture/user', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const result = await response.json();
                    preview.src = result.url + '?t=' + Date.now(); // Cache bust
                    preview.classList.remove('profile-picture-loading');

                    // Reload page to update sidebar
                    setTimeout(() => window.location.reload(), 500);
                } else {
                    const error = await response.json();
                    alert(error.error || 'Failed to upload profile picture');
                    preview.classList.remove('profile-picture-loading');
                }
            } catch (error) {
                console.error('Error uploading profile picture:', error);
                alert('An error occurred while uploading the profile picture');
                preview.classList.remove('profile-picture-loading');
            }

            // Reset input
            input.value = '';
        }

        async function deleteProfilePicture() {
            if (!confirm('Are you sure you want to remove your profile picture?')) {
                return;
            }

            try {
                const response = await fetch('/api/v1/profile-picture/user', {
                    method: 'DELETE'
                });

                if (response.ok) {
                    window.location.reload();
                } else {
                    const error = await response.json();
                    alert(error.error || 'Failed to delete profile picture');
                }
            } catch (error) {
                console.error('Error deleting profile picture:', error);
                alert('An error occurred while deleting the profile picture');
            }
        }
    </script>
}
