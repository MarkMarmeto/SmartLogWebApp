@page
@model SmartLog.Web.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logged out";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                <i class="bi bi-check-circle display-1 text-success"></i>
                <h2 class="mt-3">You have been logged out</h2>
                <p class="text-muted">Thank you for using SmartLog.</p>
                <a asp-page="/Account/Login" class="btn btn-primary mt-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign in again
                </a>
            </div>
        </div>
    </div>
</div>
