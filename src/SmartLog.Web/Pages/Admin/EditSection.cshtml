@page "{id:guid}"
@model SmartLog.Web.Pages.Admin.EditSectionModel
@{
    ViewData["Title"] = "Edit Section";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Section</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Input.Id" />
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">Grade Level</label>
                            <input type="text" class="form-control" value="@Model.GradeLevelName" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ProgramId" class="form-label">Program <span class="text-danger">*</span></label>
                            <select asp-for="Input.ProgramId" class="form-select" required>
                                <option value="">Select program...</option>
                                @foreach (var program in Model.Programs)
                                {
                                    <option value="@program.Id">@program.Code — @program.Name</option>
                                }
                            </select>
                            <span asp-validation-for="Input.ProgramId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Name" class="form-label">Section Name</label>
                            <input asp-for="Input.Name" class="form-control" />
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.AdviserId" class="form-label">Adviser</label>
                            <select asp-for="Input.AdviserId" class="form-select">
                                <option value="">No adviser assigned</option>
                                @foreach (var faculty in Model.Faculty)
                                {
                                    <option value="@faculty.Id">@faculty.FullName</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Capacity" class="form-label">Capacity</label>
                            <input asp-for="Input.Capacity" type="number" class="form-control" />
                            <span asp-validation-for="Input.Capacity" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Input.IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Save Changes
                            </button>
                            <a asp-page="/Admin/Sections" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
