@page
@model SmartLog.Web.Pages.Admin.CreateUserModel
@{
    ViewData["Title"] = "Create User";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-person-plus me-2"></i>Create New User</h1>
        <a asp-page="/Admin/Users" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Users
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.Username" class="form-label"></label>
                            <input asp-for="Input.Username" class="form-control" />
                            <span asp-validation-for="Input.Username" class="text-danger"></span>
                            <div class="form-text">Lowercase letters, numbers, dots, and underscores only</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" type="email" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.FirstName" class="form-label"></label>
                            <input asp-for="Input.FirstName" class="form-control" />
                            <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.LastName" class="form-label"></label>
                            <input asp-for="Input.LastName" class="form-control" />
                            <span asp-validation-for="Input.LastName" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label"></label>
                            <input asp-for="Input.PhoneNumber" class="form-control" type="tel" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            <div class="form-text">Optional</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.Role" class="form-label"></label>
                            <select asp-for="Input.Role" class="form-select">
                                <option value="">-- Select Role --</option>
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="Input.Role" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle me-2"></i>Create User
                    </button>
                    <a asp-page="/Admin/Users" class="btn btn-secondary btn-lg ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.GeneratedPassword))
    {
        <div class="card mt-4 border-success">
            <div class="card-header bg-success text-white">
                <i class="bi bi-check-circle me-2"></i>User Created Successfully
            </div>
            <div class="card-body">
                <h5>Temporary Password</h5>
                <p class="lead">
                    <strong>Username:</strong> @Model.Input.Username<br/>
                    <strong>Password:</strong> <code class="fs-5">@Model.GeneratedPassword</code>
                </p>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong>Important:</strong> Copy this password now. It will not be shown again.
                    The user should change it on first login.
                </div>
                <button class="btn btn-outline-primary" onclick="copyPassword()">
                    <i class="bi bi-clipboard me-1"></i>Copy Password
                </button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function copyPassword() {
            const password = '@Model.GeneratedPassword';
            navigator.clipboard.writeText(password).then(() => {
                alert('Password copied to clipboard!');
            });
        }
    </script>
}
