@page
@model SmartLog.Web.Pages.Admin.SectionsModel
@{
    ViewData["Title"] = "Sections";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Sections</h1>
        <a asp-page="/Admin/CreateSection" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Create Section
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <label for="gradeId" class="form-label">Filter by Grade Level</label>
                    <select class="form-select" id="gradeId" name="gradeId">
                        <option value="">All Grades</option>
                        @foreach (var grade in Model.GradeLevels)
                        {
                            <option value="@grade.Id" selected="@(Model.GradeId == grade.Id)">@grade.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-filter me-1"></i>Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="bi bi-grid-3x3 me-2"></i>All Sections
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Grade Level</th>
                            <th>Program</th>
                            <th>Section</th>
                            <th>Adviser</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var section in Model.Sections)
                        {
                            <tr>
                                <td>@(section.GradeLevel.Name)</td>
                                <td><span class="badge bg-light text-dark border">@(section.Program?.Code ?? "—")</span></td>
                                <td><strong>@(section.Name)</strong></td>
                                <td>@(section.Adviser?.FullName ?? "Not assigned")</td>
                                <td>@(section.Capacity) students</td>
                                <td>
                                    @if (section.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-page="/Admin/EditSection" asp-route-id="@(section.Id)" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    @if (User.IsInRole("SuperAdmin"))
                                    {
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@(section.Id)" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger ms-1"
                                                    onclick="return confirm('Permanently delete section \'@(section.Name)\'? This cannot be undone.')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/Sections"
                               asp-route-pageNumber="@(Model.PageNumber - 1)"
                               asp-route-gradeId="@Model.GradeId">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                <a class="page-link" asp-page="/Admin/Sections"
                                   asp-route-pageNumber="@i"
                                   asp-route-gradeId="@Model.GradeId">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/Sections"
                               asp-route-pageNumber="@(Model.PageNumber + 1)"
                               asp-route-gradeId="@Model.GradeId">Next</a>
                        </li>
                    </ul>
                </nav>
                <p class="text-center text-muted mt-2">
                    Showing @Model.Sections.Count of @Model.TotalSections sections
                </p>
            </div>
        }
    </div>
</div>
