@page
@model SmartLog.Web.Pages.Admin.SectionsModel
@{
    ViewData["Title"] = "Sections";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Sections</h1>
        <a asp-page="/Admin/CreateSection" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Create Section
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <label for="gradeId" class="form-label">Filter by Grade Level</label>
                    <select class="form-select" id="gradeId" name="gradeId">
                        <option value="">All Grades</option>
                        @foreach (var grade in Model.GradeLevels)
                        {
                            <option value="@grade.Id" selected="@(Model.GradeId == grade.Id)">@grade.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-filter me-1"></i>Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="bi bi-grid-3x3 me-2"></i>All Sections
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Grade Level</th>
                            <th>Section</th>
                            <th>Adviser</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var section in Model.Sections)
                        {
                            <tr>
                                <td>@(section.GradeLevel.Name)</td>
                                <td><strong>@(section.Name)</strong></td>
                                <td>@(section.Adviser?.FullName ?? "Not assigned")</td>
                                <td>@(section.Capacity) students</td>
                                <td>
                                    @if (section.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-page="/Admin/EditSection" asp-route-id="@(section.Id)" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
