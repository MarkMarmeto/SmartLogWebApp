@page "/Admin/PrintIdCards/Section/{sectionId:guid}"
@model SmartLog.Web.Pages.Admin.PrintIdCardsModel
@{
    ViewData["Title"] = "Print ID Cards";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Print ID Cards — @Model.Section.Name</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f0f0f0;
            padding: 24px;
        }

        .controls {
            max-width: 820px;
            margin: 0 auto 16px;
            display: flex;
            gap: 10px;
            align-items: center;
        }
        .controls h1 { font-size: 15px; font-weight: 600; color: #333; flex: 1; }
        .btn {
            padding: 8px 18px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .btn-primary   { background: #2C5F5D; color: #fff; }
        .btn-secondary { background: #fff; color: #555; border: 1px solid #ccc; }
        .btn:hover     { opacity: .85; }

        .skip-warning {
            max-width: 820px;
            margin: 0 auto 16px;
            padding: 10px 14px;
            background: #fff3cd;
            border: 1px solid #ffeeba;
            border-radius: 4px;
            color: #856404;
            font-size: 13px;
        }
        .skip-warning ul { margin: 6px 0 0 18px; padding: 0; }

        .empty {
            max-width: 820px;
            margin: 80px auto;
            text-align: center;
            color: #888;
            font-size: 16px;
        }

        /* A4 grid: 2 columns × 5 rows per page */
        .card-grid {
            display: grid;
            grid-template-columns: 85.6mm 85.6mm;
            gap: 4mm;
            justify-content: center;
            max-width: 820px;
            margin: 0 auto;
        }

        @@media print {
            @@page { size: A4 portrait; margin: 8mm; }
            body { background: #fff; padding: 0; margin: 0; }
            .controls, .skip-warning, .empty { display: none !important; }
            .card-grid { gap: 4mm; max-width: none; }
            .id-card {
                box-shadow: none !important;
                page-break-inside: avoid;
                break-inside: avoid;
            }
        }
    </style>
</head>
<body>

    <div class="controls">
        <h1>
            @Model.Section.GradeLevel.Name &mdash; @Model.Section.Name
            &middot;
            @Model.Cards.Count student@(Model.Cards.Count == 1 ? "" : "s")
        </h1>
        @if (Model.Cards.Count > 0)
        {
            <button class="btn btn-primary" onclick="window.print()">&#x1F5A8; Print</button>
        }
        <button class="btn btn-secondary" onclick="window.history.back()">&#x2715; Close</button>
    </div>

    @if (Model.SkippedStudents.Count > 0)
    {
        <div class="skip-warning">
            <strong>@Model.SkippedStudents.Count student@(Model.SkippedStudents.Count == 1 ? "" : "s") skipped</strong> — no valid QR code:
            <ul>
                @foreach (var s in Model.SkippedStudents)
                {
                    <li>
                        @s.FullName (@s.StudentId) —
                        <a href="/Admin/StudentDetails/@s.Id">view profile to regenerate QR</a>
                    </li>
                }
            </ul>
        </div>
    }

    @if (Model.Cards.Count == 0)
    {
        <div class="empty">No students to print for this section.</div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var card in Model.Cards)
            {
                <partial name="_StudentIdCard" model="card" />
            }
        </div>
    }

</body>
</html>
