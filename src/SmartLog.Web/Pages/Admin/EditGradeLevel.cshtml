@page "{id:int}"
@model SmartLog.Web.Pages.Admin.EditGradeLevelModel
@{
    ViewData["Title"] = "Edit Grade Level";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Grade Level</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Input.Id" />
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Code" class="form-label">Grade Code</label>
                            <input asp-for="Input.Code" class="form-control" readonly />
                            <div class="form-text">Code cannot be changed</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Name" class="form-label">Display Name</label>
                            <input asp-for="Input.Name" class="form-control" />
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="Input.SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="Input.SortOrder" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Input.IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Save Changes
                            </button>
                            <a asp-page="/Admin/GradeLevels" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
