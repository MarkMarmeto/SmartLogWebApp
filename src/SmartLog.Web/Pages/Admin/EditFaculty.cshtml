@page "{id:guid}"
@model SmartLog.Web.Pages.Admin.EditFacultyModel
@{
    ViewData["Title"] = "Edit Faculty";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Faculty Member</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Employee ID:</strong> <code>@Model.Faculty.EmployeeId</code> (cannot be changed)
                    </div>

                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Input.Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.FirstName" class="form-label"></label>
                                <input asp-for="Input.FirstName" class="form-control" />
                                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.LastName" class="form-label"></label>
                                <input asp-for="Input.LastName" class="form-control" />
                                <span asp-validation-for="Input.LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Department" class="form-label"></label>
                                <select asp-for="Input.Department" class="form-select">
                                    <option value="">-- Select Department --</option>
                                    @foreach (var dept in Model.Departments)
                                    {
                                        <option value="@dept">@dept</option>
                                    }
                                </select>
                                <span asp-validation-for="Input.Department" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Position" class="form-label"></label>
                                <input asp-for="Input.Position" class="form-control" placeholder="e.g., Senior Teacher" />
                                <span asp-validation-for="Input.Position" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Email" class="form-label"></label>
                                <input asp-for="Input.Email" type="email" class="form-control" placeholder="faculty@example.com" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                                <input asp-for="Input.PhoneNumber" type="tel" class="form-control" placeholder="e.g., +63 912 345 6789" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.HireDate" class="form-label"></label>
                                <input asp-for="Input.HireDate" type="date" class="form-control" />
                                <span asp-validation-for="Input.HireDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.ExternalEmployeeId" class="form-label"></label>
                                <input asp-for="Input.ExternalEmployeeId" class="form-control" placeholder="e.g., Old employee number" />
                                <span asp-validation-for="Input.ExternalEmployeeId" class="text-danger"></span>
                                <small class="form-text text-muted">Optional: External or legacy employee ID</small>
                            </div>
                        </div>

                        <hr class="my-4" />
                        <h5>Profile Picture</h5>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Current Profile Picture</label>
                                @if (!string.IsNullOrEmpty(Model.CurrentProfilePicturePath))
                                {
                                    <div class="mb-2">
                                        <img src="@Model.CurrentProfilePicturePath"
                                             style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover;" />
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No profile picture uploaded</p>
                                }
                                <label asp-for="Input.ProfilePicture" class="form-label">Upload New Picture</label>
                                <input asp-for="Input.ProfilePicture" type="file" class="form-control"
                                       accept="image/*" onchange="previewImage(this)" />
                                <span asp-validation-for="Input.ProfilePicture" class="text-danger"></span>
                                <small class="form-text text-muted">JPG, PNG, or GIF. Max 5MB. Leave empty to keep current picture.</small>
                            </div>
                        </div>
                        <div id="imagePreview" class="text-center mb-3" style="display:none;">
                            <img id="previewImg" style="max-width: 200px; border-radius: 10px;" />
                        </div>

                        <hr class="my-4" />
                        <h5>User Account Link</h5>

                        <div class="mb-3">
                            <label asp-for="Input.UserId" class="form-label"></label>
                            <select asp-for="Input.UserId" class="form-select">
                                @foreach (var user in Model.AvailableUsers)
                                {
                                    <option value="@user.Value" selected="@user.Selected">@user.Text</option>
                                }
                            </select>
                            <span asp-validation-for="Input.UserId" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Link this faculty member to a system user account for login access.
                                Each user account can only be linked to one faculty member.
                            </small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="/Admin/FacultyDetails" asp-route-id="@Model.Faculty.Id" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Preview profile picture before upload
        function previewImage(input) {
            const preview = document.getElementById('imagePreview');
            const img = document.getElementById('previewImg');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    img.src = e.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display = 'none';
            }
        }
    </script>
}
