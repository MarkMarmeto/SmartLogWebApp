@page
@model SmartLog.Web.Pages.Admin.PrintEnrollmentStickerModel
@{
    ViewData["Title"] = "Print Enrollment Stickers";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Enrollment Stickers — S.Y. @Model.AcademicYear</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f0f0f0;
            padding: 20px;
        }

        .controls {
            max-width: 800px;
            margin: 0 auto 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .controls h1 {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            flex: 1;
        }

        .btn {
            padding: 7px 16px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .btn-primary   { background: #2C5F5D; color: #fff; }
        .btn-secondary { background: #fff; color: #555; border: 1px solid #ccc; }
        .btn:hover     { opacity: .85; }

        /* Sticker grid — 2 per row at screen size */
        .sticker-grid {
            max-width: 800px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }

        /* Individual sticker — ~75mm × 20mm */
        .sticker {
            background: #fff;
            border: 1px dashed #bbb;
            padding: 7px 12px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 56px;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .sticker-name {
            font-size: 11px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sticker-id {
            font-size: 9px;
            color: #888;
            font-family: 'Courier New', monospace;
            margin-bottom: 4px;
        }

        .sticker-info {
            font-size: 10px;
            font-weight: 600;
            color: #2C5F5D;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .empty {
            text-align: center;
            padding: 40px;
            color: #888;
            font-size: 14px;
        }

        @@media print {
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            body { background: #fff; padding: 5mm; }
            .controls { display: none; }

            .sticker-grid {
                max-width: 100%;
                gap: 4mm;
                grid-template-columns: repeat(2, 1fr);
            }

            .sticker {
                /* ~75mm × 20mm sticker size */
                min-height: 20mm;
                padding: 3mm 4mm;
                border: 1px dashed #999;
                break-inside: avoid;
            }
        }
    </style>
</head>
<body>

    <div class="controls">
        <h1>Enrollment Stickers — S.Y. @Model.AcademicYear (@Model.Stickers.Count sticker@(Model.Stickers.Count == 1 ? "" : "s"))</h1>
        <button class="btn btn-primary" onclick="window.print()">&#x1F5A8; Print</button>
        <button class="btn btn-secondary" onclick="window.close()">&#x2715; Close</button>
    </div>

    @if (!Model.Stickers.Any())
    {
        <div class="empty">No students found for the selected filter.</div>
    }
    else
    {
        <div class="sticker-grid">
            @foreach (var entry in Model.Stickers)
            {
                <div class="sticker">
                    <div class="sticker-name">@entry.Student.FullName</div>
                    <div class="sticker-id">@entry.Student.StudentId</div>
                    <div class="sticker-info">@entry.DisplayLine</div>
                </div>
            }
        </div>
    }

</body>
</html>
