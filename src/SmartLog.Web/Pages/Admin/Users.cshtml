@page
@model SmartLog.Web.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>User Management</h1>
        <a asp-page="/Admin/CreateUser" class="btn btn-primary">
            <i class="bi bi-person-plus me-1"></i>Create New User
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* US0013: Search and Filter *@
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="searchTerm" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                           value="@Model.SearchTerm" placeholder="Name or username...">
                </div>
                <div class="col-md-3">
                    <label for="roleFilter" class="form-label">Role</label>
                    <select class="form-select" id="roleFilter" name="roleFilter">
                        <option value="">All Roles</option>
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role" selected="@(Model.RoleFilter == role)">@role</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="">All</option>
                        <option value="active" selected="@(Model.StatusFilter == "active")">Active</option>
                        <option value="inactive" selected="@(Model.StatusFilter == "inactive")">Inactive</option>
                        <option value="locked" selected="@(Model.StatusFilter == "locked")">Locked</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                    <a asp-page="/Admin/Users" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="bi bi-people me-2"></i>All Users
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.UserName</td>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge bg-secondary me-1">@role</span>
                                    }
                                </td>
                                <td>
                                    @if (!user.IsActive)
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                    else if (user.IsLockedOut)
                                    {
                                        <span class="badge bg-warning text-dark">Locked</span>
                                        @if (user.LockoutEnd.HasValue)
                                        {
                                            <small class="text-muted d-block">
                                                Until @user.LockoutEnd.Value.ToLocalTime().ToString("g")
                                            </small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    @if (user.MustChangePassword)
                                    {
                                        <span class="badge bg-info text-white d-block mt-1" title="Must change password on next login">
                                            <i class="bi bi-key me-1"></i>Password Change Required
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        @if (!user.IsCurrentUser && user.CanEdit)
                                        {
                                            <a asp-page="/Admin/EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }

                                        @if (!user.IsCurrentUser && user.CanEdit)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    title="Reset Password"
                                                    onclick="resetPassword('@user.Id', '@user.UserName')">
                                                <i class="bi bi-key"></i>
                                            </button>
                                        }

                                        @if (user.IsLockedOut)
                                        {
                                            <form method="post" asp-page-handler="UnlockAccount" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-warning" title="Unlock Account">
                                                    <i class="bi bi-unlock"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (!user.IsCurrentUser && user.CanDeactivate)
                                        {
                                            @if (user.IsActive)
                                            {
                                                <form method="post" asp-page-handler="DeactivateUser" class="d-inline" onsubmit="return confirm('Are you sure you want to deactivate this user? They will no longer be able to log in.');">
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="ReactivateUser" class="d-inline">
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/Users"
                               asp-route-pageNumber="@(Model.PageNumber - 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-roleFilter="@Model.RoleFilter"
                               asp-route-statusFilter="@Model.StatusFilter">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                <a class="page-link" asp-page="/Admin/Users"
                                   asp-route-pageNumber="@i"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-roleFilter="@Model.RoleFilter"
                                   asp-route-statusFilter="@Model.StatusFilter">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/Users"
                               asp-route-pageNumber="@(Model.PageNumber + 1)"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-roleFilter="@Model.RoleFilter"
                               asp-route-statusFilter="@Model.StatusFilter">Next</a>
                        </li>
                    </ul>
                </nav>
                <p class="text-center text-muted mt-2">
                    Showing @Model.Users.Count of @Model.TotalUsers users
                </p>
            </div>
        }
    </div>
</div>

@* US0012: Reset Password Modal *@
<div class="modal fade" id="resetPasswordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This will generate a new temporary password for <strong id="resetUsername"></strong>.</p>
                <p>The user will need to change their password on next login.</p>
                <div id="resetPasswordResult" style="display:none;" class="alert alert-success">
                    <strong>New temporary password:</strong>
                    <code id="newPassword" class="fs-5"></code>
                    <button class="btn btn-sm btn-outline-primary ms-2" onclick="copyResetPassword()">
                        <i class="bi bi-clipboard"></i> Copy
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmResetBtn" onclick="confirmReset()">
                    Reset Password
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let resetUserId = null;

        function resetPassword(userId, username) {
            resetUserId = userId;
            document.getElementById('resetUsername').textContent = username;
            document.getElementById('resetPasswordResult').style.display = 'none';
            document.getElementById('confirmResetBtn').style.display = 'block';

            const modal = new bootstrap.Modal(document.getElementById('resetPasswordModal'));
            modal.show();
        }

        function confirmReset() {
            if (!resetUserId) return;

            fetch('/Admin/Users?handler=ResetPassword', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: `userId=${resetUserId}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('newPassword').textContent = data.password;
                    document.getElementById('resetPasswordResult').style.display = 'block';
                    document.getElementById('confirmResetBtn').style.display = 'none';
                } else {
                    alert('Error: ' + (data.error || 'Failed to reset password'));
                }
            })
            .catch(error => {
                alert('Error: ' + error.message);
            });
        }

        function copyResetPassword() {
            const password = document.getElementById('newPassword').textContent;
            navigator.clipboard.writeText(password).then(() => {
                alert('Password copied to clipboard!');
            });
        }
    </script>
}

