@page
@model SmartLog.Web.Pages.Admin.ProgramsModel
@{
    ViewData["Title"] = "Programs";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-diagram-3 me-2"></i>Programs</h1>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <a asp-page="/Admin/CreateProgram" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Create Program
            </a>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <i class="bi bi-diagram-3 me-2"></i>All Programs
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Grade Levels</th>
                            <th>Sections</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var program in Model.Programs)
                        {
                            var sectionCount = program.Sections.Count;
                            <tr>
                                <td><strong>@program.Code</strong></td>
                                <td>@program.Name</td>
                                <td>
                                    @if (program.GradeLevelPrograms.Any())
                                    {
                                        <small>@string.Join(", ", program.GradeLevelPrograms.OrderBy(g => g.GradeLevel.SortOrder).Select(g => g.GradeLevel.Code))</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">None</small>
                                    }
                                </td>
                                <td>
                                    @if (sectionCount > 0)
                                    {
                                        <span class="badge bg-light text-dark border">@sectionCount</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    @if (program.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-page="/Admin/EditProgram" asp-route-id="@program.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (User.IsInRole("SuperAdmin"))
                                    {
                                        @if (sectionCount == 0)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@program.Id" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger ms-1"
                                                        onclick="return confirm('Permanently delete program \'@program.Code\'?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary ms-1" disabled
                                                    title="Assigned to sections">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
