@page
@model SmartLog.Web.Pages.Admin.AboutModel
@{
    ViewData["Title"] = "About";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card">
                <div class="card-body text-center py-5">
                    <!-- Logo -->
                    <div class="mb-3">
                        <img src="~/images/smartlog-icon.svg" alt="SmartLog" width="80" height="80" />
                    </div>
                    <div class="mb-4">
                        <img src="~/images/smartlog-logo.svg" alt="SmartLog" height="36" />
                    </div>

                    <p class="text-muted mb-4">School Attendance Management System</p>

                    <!-- Version -->
                    <div class="mb-4">
                        <span class="badge bg-light text-dark border px-3 py-2" style="font-size: 0.9rem;">
                            Version @Model.Version
                        </span>
                    </div>

                    <hr class="my-4" />

                    <!-- Description -->
                    <p class="text-muted px-3">
                        SmartLog is a comprehensive school information management system built for Philippine K-12 schools.
                        It tracks student attendance via QR code scanning, sends SMS notifications to parents,
                        and provides administrative tools for managing students, faculty, academic years, and reporting.
                    </p>

                    <hr class="my-4" />

                    <!-- Author -->
                    <div class="mb-3">
                        <small class="text-muted text-uppercase" style="letter-spacing: 1px;">Developed by</small>
                        <h5 class="fw-bold mt-2 mb-0">Mark Daniel Marmeto</h5>
                    </div>

                    <hr class="my-4" />

                    <!-- Tech Stack -->
                    <div class="mb-3">
                        <small class="text-muted text-uppercase" style="letter-spacing: 1px;">Built with</small>
                        <div class="mt-2 d-flex flex-wrap justify-content-center gap-2">
                            <span class="badge bg-light text-dark border">ASP.NET Core 8.0</span>
                            <span class="badge bg-light text-dark border">Entity Framework Core</span>
                            <span class="badge bg-light text-dark border">SQL Server</span>
                            <span class="badge bg-light text-dark border">Bootstrap 5</span>
                            <span class="badge bg-light text-dark border">Razor Pages</span>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <!-- Copyright -->
                    <p class="text-muted mb-0">
                        <small>&copy; @DateTime.Now.Year SmartLog. All rights reserved.</small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
