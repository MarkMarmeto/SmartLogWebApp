@page
@model SmartLog.Web.Pages.Admin.AttendanceDashboardModel
@{
    ViewData["Title"] = "Attendance Dashboard";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1><i class="bi bi-clipboard-check me-2"></i>Attendance Dashboard</h1>
            <p class="text-muted mb-0">Attendance for @Model.DisplayDate.ToString("MMMM dd, yyyy")</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-info" id="autoRefreshStatus">Auto-refresh: ON (every 30s)</span>
            <span class="text-muted small" id="lastUpdated">Last updated: @DateTime.Now.ToString("h:mm:ss tt")</span>
            <a asp-page="/Admin/ScanLogs" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-qr-code-scan"></i> Scan Logs
            </a>
            <button class="btn btn-outline-primary btn-sm" onclick="manualRefresh()">
                <i class="bi bi-arrow-clockwise"></i> Refresh Now
            </button>
            <button class="btn btn-outline-secondary btn-sm" onclick="toggleAutoRefresh()">
                <i class="bi bi-pause-circle"></i> Pause
            </button>
        </div>
    </div>

    @* US0034-AC1, AC2: Summary Cards *@
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Total Enrolled</h6>
                    <h2 class="card-title mb-0" id="totalEnrolled">@Model.Summary.TotalEnrolled</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Present</h6>
                    <h2 class="card-title mb-0 text-success" id="presentCount">@Model.Summary.Present</h2>
                    <small class="text-muted" id="attendanceRate">@Model.Summary.AttendanceRate%</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Absent</h6>
                    <h2 class="card-title mb-0 text-danger" id="absentCount">@Model.Summary.Absent</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Departed</h6>
                    <h2 class="card-title mb-0 text-secondary" id="departedCount">@Model.Summary.Departed</h2>
                </div>
            </div>
        </div>
    </div>

    @* US0036: Filters and Search *@
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-2">
                    <label for="selectedDate" class="form-label">Date</label>
                    <input type="date" class="form-control" id="selectedDate" name="selectedDate"
                           value="@Model.DisplayDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label for="academicYearId" class="form-label">Academic Year</label>
                    <select class="form-select" id="academicYearId" name="academicYearId">
                        @foreach (var year in Model.AcademicYears)
                        {
                            <option value="@year.Id" selected="@(Model.AcademicYearId == year.Id)">
                                @year.Name @(year.IsCurrent ? "(Current)" : "")
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="gradeFilter" class="form-label">Grade</label>
                    <select class="form-select" id="gradeFilter" name="gradeFilter">
                        <option value="">All Grades</option>
                        @foreach (var grade in Model.GradeLevelList)
                        {
                            <option value="@grade.Code" selected="@(Model.GradeFilter == grade.Code)">@grade.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="sectionFilter" class="form-label">Section</label>
                    <select class="form-select" id="sectionFilter" name="sectionFilter">
                        <option value="">All Sections</option>
                        @foreach (var sec in Model.Sections)
                        {
                            <option value="@sec" selected="@(Model.SectionFilter == sec)">@sec</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="programFilter" class="form-label">Program</label>
                    <select class="form-select" id="programFilter" name="programFilter">
                        <option value="">All Programs</option>
                        @foreach (var prog in Model.ProgramList)
                        {
                            <option value="@prog.Code" selected="@(Model.ProgramFilter == prog.Code)">@prog.Code</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="">All Status</option>
                        <option value="Present" selected="@(Model.StatusFilter == "Present")">Present</option>
                        <option value="Absent" selected="@(Model.StatusFilter == "Absent")">Absent</option>
                        <option value="Departed" selected="@(Model.StatusFilter == "Departed")">Departed</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="searchTerm" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                           value="@Model.SearchTerm" placeholder="Student name, ID, or LRN..." />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* US0034-AC3: Student Attendance List *@
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list me-2"></i>Student Attendance</span>
            <span class="badge bg-secondary">@Model.TotalRecords students</span>
        </div>
        <div class="card-body">
            <div id="attendanceTableContainer">
                @if (Model.AttendanceRecords.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Student ID</th>
                                    <th>LRN</th>
                                    <th>Name</th>
                                    <th>Grade / Section</th>
                                    <th>Status</th>
                                    <th>Entry Time</th>
                                    <th>Exit Time</th>
                                </tr>
                            </thead>
                            <tbody id="attendanceTableBody">
                                @foreach (var record in Model.AttendanceRecords)
                                {
                                    <tr>
                                        <td><code>@record.StudentIdNumber</code></td>
                                        <td><code>@(record.LRN ?? "-")</code></td>
                                        <td>@record.FullName</td>
                                        <td>Grade @record.GradeLevel - @record.Section</td>
                                        <td>
                                            @* US0034-AC4: Status Visual Indicators *@
                                            @if (record.Status == "Present")
                                            {
                                                <span class="badge bg-success">Present</span>
                                            }
                                            else if (record.Status == "Absent")
                                            {
                                                <span class="badge bg-danger">Absent</span>
                                            }
                                            else if (record.Status == "Departed")
                                            {
                                                <span class="badge bg-secondary">Departed</span>
                                            }
                                        </td>
                                        <td>
                                            @if (record.EntryTime.HasValue)
                                            {
                                                @record.EntryTime.Value.ToString("h:mm tt")
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (record.ExitTime.HasValue)
                                            {
                                                @record.ExitTime.Value.ToString("h:mm tt")
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* Pagination *@
                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                    <a class="page-link" href="?pageNumber=@(Model.PageNumber - 1)&selectedDate=@Model.DisplayDate.ToString("yyyy-MM-dd")&gradeFilter=@Model.GradeFilter&sectionFilter=@Model.SectionFilter&programFilter=@Model.ProgramFilter&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                                        Previous
                                    </a>
                                </li>
                                @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                                {
                                    <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                        <a class="page-link" href="?pageNumber=@i&selectedDate=@Model.DisplayDate.ToString("yyyy-MM-dd")&gradeFilter=@Model.GradeFilter&sectionFilter=@Model.SectionFilter&programFilter=@Model.ProgramFilter&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                                            @i
                                        </a>
                                    </li>
                                }
                                <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="?pageNumber=@(Model.PageNumber + 1)&selectedDate=@Model.DisplayDate.ToString("yyyy-MM-dd")&gradeFilter=@Model.GradeFilter&sectionFilter=@Model.SectionFilter&programFilter=@Model.ProgramFilter&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                                        Next
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="text-muted mt-3">No attendance records found for the selected filters.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        // US0037: Auto-refresh implementation
        let autoRefreshEnabled = true;
        let refreshInterval = null;
        let lastInteractionTime = Date.now();

        function startAutoRefresh() {
            if (refreshInterval) {
                clearInterval(refreshInterval);
            }

            // US0037-AC1: Auto-refresh every 30 seconds
            refreshInterval = setInterval(() => {
                // US0037-AC5: Pause if user is typing
                const timeSinceInteraction = Date.now() - lastInteractionTime;
                if (timeSinceInteraction < 5000) {
                    console.log('Skipping refresh - recent user interaction');
                    return;
                }

                if (autoRefreshEnabled && !document.hidden) {
                    refreshData();
                }
            }, 30000);
        }

        function refreshData() {
            // US0037-AC2: Show loading indicator
            const statusBadge = document.getElementById('autoRefreshStatus');
            if (statusBadge) {
                statusBadge.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Refreshing...';
            }

            const date = document.getElementById('selectedDate')?.value || '@Model.DisplayDate.ToString("yyyy-MM-dd")';
            const grade = document.getElementById('gradeFilter')?.value || '';
            const section = document.getElementById('sectionFilter')?.value || '';
            const program = document.getElementById('programFilter')?.value || '';

            // Fetch updated summary
            fetch(`/api/v1/attendance/summary?date=${date}&grade=${grade}&section=${section}&program=${program}`)
                .then(response => response.json())
                .then(data => {
                    // Update summary cards
                    document.getElementById('totalEnrolled').textContent = data.totalEnrolled;
                    document.getElementById('presentCount').textContent = data.present;
                    document.getElementById('absentCount').textContent = data.absent;
                    document.getElementById('departedCount').textContent = data.departed;
                    document.getElementById('attendanceRate').textContent = data.attendanceRate + '%';

                    // US0037-AC1: Update last updated timestamp
                    const now = new Date();
                    document.getElementById('lastUpdated').textContent =
                        `Last updated: ${now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', second: '2-digit' })}`;

                    // Restore auto-refresh status
                    if (autoRefreshEnabled && statusBadge) {
                        statusBadge.innerHTML = 'Auto-refresh: ON (every 30s)';
                        statusBadge.className = 'badge bg-info';
                    }
                })
                .catch(error => {
                    console.error('Error refreshing data:', error);
                    if (statusBadge) {
                        statusBadge.innerHTML = 'Auto-refresh: ERROR';
                        statusBadge.className = 'badge bg-danger';
                    }
                });
        }

        function manualRefresh() {
            // US0037-AC6: Manual refresh button
            refreshData();
            // Reset the 30-second timer
            startAutoRefresh();
        }

        function toggleAutoRefresh() {
            // US0037-AC8: Toggle auto-refresh on/off
            autoRefreshEnabled = !autoRefreshEnabled;

            const statusBadge = document.getElementById('autoRefreshStatus');
            const toggleBtn = event.target.closest('button');

            if (autoRefreshEnabled) {
                statusBadge.innerHTML = 'Auto-refresh: ON (every 30s)';
                statusBadge.className = 'badge bg-info';
                toggleBtn.innerHTML = '<i class="bi bi-pause-circle"></i> Pause';
                startAutoRefresh();
            } else {
                statusBadge.innerHTML = 'Auto-refresh: OFF';
                statusBadge.className = 'badge bg-secondary';
                toggleBtn.innerHTML = '<i class="bi bi-play-circle"></i> Resume';
                if (refreshInterval) {
                    clearInterval(refreshInterval);
                }
            }
        }

        // Track user interactions for US0037-AC5
        ['keydown', 'mousedown', 'touchstart'].forEach(event => {
            document.addEventListener(event, () => {
                lastInteractionTime = Date.now();
            });
        });

        // Pause refresh when tab is hidden
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                console.log('Tab hidden - pausing refresh');
            } else {
                console.log('Tab visible - resuming refresh');
                if (autoRefreshEnabled) {
                    refreshData(); // Refresh immediately when tab becomes visible
                }
            }
        });

        // Start auto-refresh on page load
        startAutoRefresh();
    </script>
}
