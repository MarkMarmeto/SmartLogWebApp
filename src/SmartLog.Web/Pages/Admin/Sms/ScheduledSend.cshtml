@page
@model SmartLog.Web.Pages.Admin.Sms.ScheduledSendModel
@{
    ViewData["Title"] = "Schedule SMS";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-clock me-2"></i>Schedule SMS</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" onsubmit="return confirmSend();">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-clock me-2"></i>Scheduled Message
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="phoneNumber" class="form-label">Phone Number <span class="text-danger">*</span></label>
                    <input type="tel" class="form-control" id="phoneNumber" name="PhoneNumber"
                           required maxlength="20" placeholder="e.g. 09171234567" />
                </div>

                <div class="mb-3">
                    <label for="message" class="form-label">Message <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="message" name="Message" rows="4"
                              required maxlength="320" placeholder="Enter your message..."></textarea>
                    <div class="form-text">
                        <span id="charCount">0</span> / 320 characters
                    </div>
                </div>

                <div class="mb-3">
                    <label for="scheduledAt" class="form-label">Schedule Time</label>
                    <input type="datetime-local" class="form-control" id="scheduledAt" name="ScheduledAt" />
                    <div class="form-text">Leave empty to send immediately</div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-send me-1"></i>Schedule SMS
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Character counter
        document.getElementById('message').addEventListener('input', function() {
            document.getElementById('charCount').textContent = this.value.length;
        });

        function confirmSend() {
            var scheduledAt = document.getElementById('scheduledAt').value;
            var msg = scheduledAt
                ? 'Schedule this SMS for ' + new Date(scheduledAt).toLocaleString() + '?'
                : 'Send this SMS immediately?';
            return confirm(msg);
        }
    </script>
}
