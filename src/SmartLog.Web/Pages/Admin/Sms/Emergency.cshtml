@page
@model SmartLog.Web.Pages.Admin.Sms.EmergencyModel
@{
    ViewData["Title"] = "Emergency Broadcast";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-exclamation-triangle text-danger me-2"></i>Emergency Broadcast</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.IsSmsEnabled)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>SMS sending is globally disabled.</strong> Messages will be queued but not sent until SMS is re-enabled in
            <a asp-page="/Admin/Sms/Settings" class="alert-link">Settings</a>.
        </div>
    }

    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Warning:</strong> This will send an SMS immediately to all targeted students with SMS enabled.
        Use this feature only for urgent announcements.
    </div>

    <form method="post" id="emergencyForm">
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-megaphone me-2"></i>Broadcast Message
            </div>
            <div class="card-body">
                @{
                    ViewData["TemplatePrefixEn"]  = Model.TemplatePrefixEn;
                    ViewData["TemplateSuffixEn"]  = Model.TemplateSuffixEn;
                    ViewData["TemplatePrefixFil"] = Model.TemplatePrefixFil;
                    ViewData["TemplateSuffixFil"] = Model.TemplateSuffixFil;
                    ViewData["MaxLength"] = 200;
                    ViewData["FormId"] = "emergencyForm";
                }
                <partial name="_MessageBodiesInput" model="Model.MessageBodies" />
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-funnel me-2"></i>Target Audience
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Select the programs and grade levels to include. All programs and grades are selected by default.</p>
                <partial name="_ProgramFirstTargeting" model="Model.ProgramsWithGrades" />
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-people me-2"></i>Estimated Recipients
            </div>
            <div class="card-body">
                <div id="recipientAlert" class="alert alert-info mb-0">
                    <i class="bi bi-people me-2"></i>
                    <strong>Estimated Recipients:</strong>
                    <span id="recipientCount">@Model.TotalActiveStudents</span> students
                    <span id="targetingSummary" class="ms-1 text-muted small"></span>
                    <span id="noRecipientsWarning" class="d-none ms-2 fw-bold text-danger">
                        <i class="bi bi-exclamation-circle me-1"></i>No recipients — adjust filter or check that students have SMS enabled.
                    </span>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="button" class="btn btn-danger btn-lg" id="submitBtn"
                    onclick="openConfirmModal()">
                <i class="bi bi-send me-1"></i>Send Emergency Broadcast
            </button>
        </div>
    </form>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white rounded-top">
                <h5 class="modal-title text-white" id="confirmModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirm Emergency Broadcast
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-4">
                    <i class="bi bi-exclamation-octagon-fill fs-5 flex-shrink-0"></i>
                    <span class="small fw-semibold">This will be sent immediately and cannot be undone.</span>
                </div>
                <div class="text-center mb-4">
                    <div class="display-6 fw-bold text-danger" id="modalRecipientCount">0</div>
                    <div class="text-muted">recipients will receive this message</div>
                    <div class="text-muted small mt-1" id="modalTargetScope"></div>
                </div>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span class="text-muted small">Priority</span>
                        <span class="badge bg-danger">Emergency</span>
                    </li>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <span class="text-muted small">Language mode</span>
                        <span class="fw-semibold" id="modalLanguage">Both</span>
                    </li>
                    <li class="list-group-item px-0">
                        <div class="text-muted small mb-1">English preview</div>
                        <div class="bg-light rounded p-2 small text-break" id="modalEnPreview" style="max-height:60px;overflow:hidden;"></div>
                    </li>
                    <li class="list-group-item px-0 d-none" id="modalFilRow">
                        <div class="text-muted small mb-1">Filipino preview</div>
                        <div class="bg-light rounded p-2 small text-break" id="modalFilPreview" style="max-height:60px;overflow:hidden;"></div>
                    </li>
                </ul>
                <div class="alert alert-warning mb-0 py-2 small">
                    <i class="bi bi-info-circle me-1"></i>SMS credits will be consumed for each recipient.
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 pt-0">
                <button type="button" class="btn btn-outline-secondary flex-fill" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Go Back
                </button>
                <button type="button" class="btn btn-danger flex-fill" id="modalConfirmBtn" onclick="submitForm()">
                    <i class="bi bi-send me-1"></i>Send Emergency Now
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sms-broadcast-targeting.js"></script>
    <script>
        const totalStudents = @Model.TotalActiveStudents;
        let currentRecipientCount = totalStudents;

        window.onTargetingChanged = function (json) {
            const filters = JSON.parse(json || '[]');
            fetchRecipientCount(filters.length > 0 ? json : null);
        };

        function fetchRecipientCount(targetingJson) {
            const params = targetingJson
                ? `?handler=RecipientCount&targetingJson=${encodeURIComponent(targetingJson)}`
                : '?handler=RecipientCount';
            fetch(params).then(r => r.json()).then(data => {
                currentRecipientCount = data.count;
                document.getElementById('recipientCount').textContent = data.count;
                applyWarning(data.count);
            });
        }

        function applyWarning(count) {
            const alertEl = document.getElementById('recipientAlert');
            const warning = document.getElementById('noRecipientsWarning');
            const submitBtn = document.getElementById('submitBtn');
            if (count === 0) {
                alertEl.className = 'alert alert-danger mb-0';
                warning.classList.remove('d-none');
                submitBtn.disabled = true;
            } else {
                alertEl.className = 'alert alert-info mb-0';
                warning.classList.add('d-none');
                submitBtn.disabled = false;
            }
        }

        function openConfirmModal() {
            const form = document.getElementById('emergencyForm');
            if (!form.checkValidity()) { form.reportValidity(); return; }
            if (currentRecipientCount === 0) return;

            const bodies = window.getMessageBodiesForModal ? window.getMessageBodiesForModal() : {};
            const modeLabels = { Both: 'Both (EN + Filipino)', EnglishOnly: 'English only', FilipinoOnly: 'Filipino only' };
            const truncate = t => t && t.length > 80 ? t.substring(0, 80) + '…' : (t || '');

            document.getElementById('modalRecipientCount').textContent = currentRecipientCount.toLocaleString();
            document.getElementById('modalTargetScope').textContent =
                document.getElementById('targetingSummary').textContent || 'All programs and grades';
            document.getElementById('modalLanguage').textContent = modeLabels[bodies.mode] || bodies.mode;
            document.getElementById('modalEnPreview').textContent = truncate(bodies.enBody);

            const filRow = document.getElementById('modalFilRow');
            if (bodies.mode !== 'EnglishOnly' && bodies.filBody) {
                filRow.classList.remove('d-none');
                document.getElementById('modalFilPreview').textContent = truncate(bodies.filBody);
            } else {
                filRow.classList.add('d-none');
            }

            new bootstrap.Modal(document.getElementById('confirmModal')).show();
        }

        function submitForm() {
            document.getElementById('modalConfirmBtn').disabled = true;
            document.getElementById('modalConfirmBtn').innerHTML =
                '<span class="spinner-border spinner-border-sm me-1"></span>Sending…';
            document.getElementById('emergencyForm').submit();
        }

        document.addEventListener('DOMContentLoaded', function () {
            window.initBroadcastTargeting();
        });
    </script>
}
