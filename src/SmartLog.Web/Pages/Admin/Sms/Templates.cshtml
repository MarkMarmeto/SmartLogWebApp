@page
@model SmartLog.Web.Pages.Admin.Sms.TemplatesModel
@{
    ViewData["Title"] = "SMS Templates";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-text me-2"></i>SMS Templates</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <i class="bi bi-collection me-2"></i>Message Templates
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Type</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var template in Model.Templates)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@template.Code</span></td>
                                <td>@template.Name</td>
                                <td>
                                    @if (template.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (template.IsSystem)
                                    {
                                        <span class="badge bg-info">System</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Custom</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            onclick="viewTemplate(@template.Id)">
                                        <i class="bi bi-eye"></i> View
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary"
                                            onclick="editTemplate(@template.Id)">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- View Template Modal -->
<div class="modal fade" id="viewTemplateModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">View Template</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="viewTemplateContent"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Template Modal -->
<div class="modal fade" id="editTemplateModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Template</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editTemplateId" name="templateId" />

                    <div class="mb-3">
                        <label class="form-label">Code</label>
                        <input type="text" class="form-control" id="editCode" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" id="editName" name="name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">English Template</label>
                        <textarea class="form-control" id="editTemplateEn" name="templateEn" rows="3" required></textarea>
                        <small class="text-muted">Available placeholders: <span id="editPlaceholders"></span></small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Filipino Template</label>
                        <textarea class="form-control" id="editTemplateFil" name="templateFil" rows="3" required></textarea>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="editIsActive" name="isActive" />
                        <label class="form-check-label" for="editIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const templates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Templates, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        function viewTemplate(id) {
            const template = templates.find(t => t.id === id);
            if (!template) {
                console.error('Template not found:', id);
                return;
            }

            const content = `
                <div class="mb-3">
                    <label class="fw-bold">Code:</label>
                    <span class="badge bg-primary ms-2">${template.code}</span>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Name:</label>
                    <p>${template.name}</p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">English Template:</label>
                    <pre class="bg-light p-2 rounded">${template.templateEn}</pre>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Filipino Template:</label>
                    <pre class="bg-light p-2 rounded">${template.templateFil}</pre>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Placeholders:</label>
                    <p>${template.availablePlaceholders || 'None'}</p>
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Status:</label>
                    <span class="badge ${template.isActive ? 'bg-success' : 'bg-secondary'}">${template.isActive ? 'Active' : 'Inactive'}</span>
                    ${template.isSystem ? '<span class="badge bg-info ms-2">System Template</span>' : ''}
                </div>
            `;

            document.getElementById('viewTemplateContent').innerHTML = content;
            new bootstrap.Modal(document.getElementById('viewTemplateModal')).show();
        }

        function editTemplate(id) {
            const template = templates.find(t => t.id === id);
            if (!template) {
                console.error('Template not found:', id);
                return;
            }

            document.getElementById('editTemplateId').value = template.id;
            document.getElementById('editCode').value = template.code;
            document.getElementById('editName').value = template.name;
            document.getElementById('editTemplateEn').value = template.templateEn;
            document.getElementById('editTemplateFil').value = template.templateFil;
            document.getElementById('editPlaceholders').textContent = template.availablePlaceholders || 'None';
            document.getElementById('editIsActive').checked = template.isActive;

            new bootstrap.Modal(document.getElementById('editTemplateModal')).show();
        }

        // Debug: Log templates on page load
        console.log('Templates loaded:', templates);
    </script>
}
