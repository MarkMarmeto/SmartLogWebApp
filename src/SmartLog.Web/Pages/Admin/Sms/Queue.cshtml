@page
@model SmartLog.Web.Pages.Admin.Sms.QueueModel
@{
    ViewData["Title"] = "SMS Queue";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-list-ul me-2"></i>SMS Queue</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filters -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="">All</option>
                        <option value="0" selected="@(Model.StatusFilter == "0")">Pending</option>
                        <option value="1" selected="@(Model.StatusFilter == "1")">Processing</option>
                        <option value="2" selected="@(Model.StatusFilter == "2")">Sent</option>
                        <option value="3" selected="@(Model.StatusFilter == "3")">Failed</option>
                        <option value="4" selected="@(Model.StatusFilter == "4")">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="messageTypeFilter" class="form-label">Message Type</label>
                    <select class="form-select" id="messageTypeFilter" name="messageTypeFilter">
                        <option value="">All</option>
                        <option value="ATTENDANCE" selected="@(Model.MessageTypeFilter == "ATTENDANCE")">Attendance</option>
                        <option value="CALENDAR" selected="@(Model.MessageTypeFilter == "CALENDAR")">Calendar</option>
                        <option value="EMERGENCY" selected="@(Model.MessageTypeFilter == "EMERGENCY")">Emergency</option>
                        <option value="CUSTOM" selected="@(Model.MessageTypeFilter == "CUSTOM")">Custom</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="phoneSearch" class="form-label">Phone Number</label>
                    <input type="text" class="form-control" id="phoneSearch" name="phoneSearch"
                           value="@Model.PhoneSearch" placeholder="Search phone number...">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-search me-1"></i>Filter
                    </button>
                    <a asp-page="/Admin/Sms/Queue" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Queue Table -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-envelope me-2"></i>Queued Messages (@Model.TotalMessages)
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Created</th>
                            <th>Phone</th>
                            <th>Message</th>
                            <th>Type</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Retry</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.QueuedMessages.Any())
                        {
                            @foreach (var msg in Model.QueuedMessages)
                            {
                                <tr>
                                    <td>@msg.Id</td>
                                    <td class="text-nowrap">@msg.CreatedAt.ToLocalTime().ToString("MMM dd HH:mm")</td>
                                    <td>@msg.PhoneNumber</td>
                                    <td class="text-truncate" style="max-width: 300px;" title="@msg.Message">
                                        @msg.Message
                                    </td>
                                    <td><span class="badge bg-secondary">@msg.MessageType</span></td>
                                    <td>
                                        @switch (msg.Priority)
                                        {
                                            case SmartLog.Web.Data.Entities.SmsPriority.Emergency:
                                                <span class="badge bg-danger">Emergency</span>
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsPriority.High:
                                                <span class="badge bg-warning">High</span>
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsPriority.Normal:
                                                <span class="badge bg-info">Normal</span>
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsPriority.Low:
                                                <span class="badge bg-secondary">Low</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @switch (msg.Status)
                                        {
                                            case SmartLog.Web.Data.Entities.SmsStatus.Pending:
                                                @if (msg.ScheduledAt.HasValue && msg.ScheduledAt > DateTime.UtcNow)
                                                {
                                                    <span class="badge bg-info">Scheduled</span>
                                                    <small class="text-muted d-block">@msg.ScheduledAt.Value.ToLocalTime().ToString("MMM dd HH:mm")</small>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Pending</span>
                                                }
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsStatus.Processing:
                                                <span class="badge bg-info">Processing</span>
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsStatus.Sent:
                                                <span class="badge bg-success">Sent</span>
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsStatus.Failed:
                                                <span class="badge bg-danger">Failed</span>
                                                break;
                                            case SmartLog.Web.Data.Entities.SmsStatus.Cancelled:
                                                <span class="badge bg-secondary">Cancelled</span>
                                                break;
                                        }
                                    </td>
                                    <td>@msg.RetryCount / @msg.MaxRetries</td>
                                    <td>
                                        @if (msg.Status == SmartLog.Web.Data.Entities.SmsStatus.Pending ||
                                             msg.Status == SmartLog.Web.Data.Entities.SmsStatus.Failed)
                                        {
                                            <form method="post" asp-page-handler="Cancel" class="d-inline"
                                                  onsubmit="return confirm('Cancel this message?');">
                                                <input type="hidden" name="queueId" value="@msg.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-circle"></i> Cancel
                                                </button>
                                            </form>
                                        }
                                        @if (!string.IsNullOrEmpty(msg.ErrorMessage))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-info"
                                                    onclick="showError('@msg.Id', '@msg.ErrorMessage')">
                                                <i class="bi bi-info-circle"></i> Error
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted">No messages in queue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/Sms/Queue"
                               asp-route-pageNumber="@(Model.PageNumber - 1)"
                               asp-route-statusFilter="@Model.StatusFilter"
                               asp-route-messageTypeFilter="@Model.MessageTypeFilter"
                               asp-route-phoneSearch="@Model.PhoneSearch">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                <a class="page-link" asp-page="/Admin/Sms/Queue"
                                   asp-route-pageNumber="@i"
                                   asp-route-statusFilter="@Model.StatusFilter"
                                   asp-route-messageTypeFilter="@Model.MessageTypeFilter"
                                   asp-route-phoneSearch="@Model.PhoneSearch">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/Sms/Queue"
                               asp-route-pageNumber="@(Model.PageNumber + 1)"
                               asp-route-statusFilter="@Model.StatusFilter"
                               asp-route-messageTypeFilter="@Model.MessageTypeFilter"
                               asp-route-phoneSearch="@Model.PhoneSearch">Next</a>
                        </li>
                    </ul>
                </nav>
                <p class="text-center text-muted mt-2">
                    Page @Model.PageNumber of @Model.TotalPages
                </p>
            </div>
        }
    </div>
</div>

<!-- Error Modal -->
<div class="modal fade" id="errorModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Error Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="errorMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showError(id, message) {
            document.getElementById('errorMessage').textContent = message;
            new bootstrap.Modal(document.getElementById('errorModal')).show();
        }
    </script>
}
