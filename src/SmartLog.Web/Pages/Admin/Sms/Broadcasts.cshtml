@page
@model SmartLog.Web.Pages.Admin.Sms.BroadcastsModel
@using SmartLog.Web.Data.Entities
@{
    ViewData["Title"] = "Broadcast History";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-broadcast me-2"></i>Broadcast History</h1>
        <div class="d-flex gap-2">
            <a asp-page="/Admin/Sms/Announcement" class="btn btn-primary">
                <i class="bi bi-megaphone me-1"></i>New Announcement
            </a>
            <a asp-page="/Admin/Sms/Emergency" class="btn btn-danger">
                <i class="bi bi-exclamation-triangle me-1"></i>Emergency
            </a>
            <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>SMS Dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Broadcasts.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="mt-3 text-muted">No broadcasts yet. Send an announcement or emergency alert to get started.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Type</th>
                                <th>Message</th>
                                <th>Grades</th>
                                <th>Recipients</th>
                                <th>Status</th>
                                <th>Scheduled</th>
                                <th>Created</th>
                                <th>By</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.Broadcasts)
                            {
                                <tr>
                                    <td>
                                        @if (b.Type == "EMERGENCY")
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Emergency</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary"><i class="bi bi-megaphone me-1"></i>Announcement</span>
                                        }
                                    </td>
                                    <td style="max-width: 280px;">
                                        <span class="text-truncate d-block" title="@b.Message">@b.Message</span>
                                        @if (!string.IsNullOrEmpty(b.Language))
                                        {
                                            <small class="text-muted">@b.Language only</small>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var gradeList = string.IsNullOrEmpty(b.AffectedGrades)
                                                ? new List<string>()
                                                : System.Text.Json.JsonSerializer.Deserialize<List<string>>(b.AffectedGrades) ?? new();
                                            var programList = string.IsNullOrEmpty(b.AffectedPrograms)
                                                ? new List<string>()
                                                : System.Text.Json.JsonSerializer.Deserialize<List<string>>(b.AffectedPrograms) ?? new();
                                            var hasNonGraded = programList.Any(p => p.Equals("Non-Graded", StringComparison.OrdinalIgnoreCase));
                                            var displayParts = new List<string>();
                                            if (gradeList.Any()) displayParts.Add(string.Join(", ", gradeList));
                                            if (hasNonGraded) displayParts.Add("Non-Graded");
                                        }
                                        @if (!displayParts.Any())
                                        {
                                            <span class="text-muted">All</span>
                                        }
                                        else
                                        {
                                            @string.Join(", ", displayParts)
                                        }
                                    </td>
                                    <td class="text-center">@b.TotalRecipients</td>
                                    <td>
                                        @switch (b.Status)
                                        {
                                            case BroadcastStatus.Pending:
                                                <span class="badge bg-secondary">Pending</span>
                                                break;
                                            case BroadcastStatus.Scheduled:
                                                <span class="badge bg-info text-dark">
                                                    <i class="bi bi-clock me-1"></i>Scheduled
                                                </span>
                                                break;
                                            case BroadcastStatus.Sending:
                                                <span class="badge bg-warning text-dark">Sending</span>
                                                break;
                                            case BroadcastStatus.Sent:
                                                <span class="badge bg-success">Sent</span>
                                                break;
                                            case BroadcastStatus.Cancelled:
                                                <span class="badge bg-secondary">Cancelled</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (b.ScheduledAt.HasValue)
                                        {
                                            <small>@Model.ToPhilippineTime(b.ScheduledAt)</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Immediate</span>
                                        }
                                    </td>
                                    <td><small>@Model.ToPhilippineTime(b.CreatedAt)</small></td>
                                    <td><small class="text-muted">@(b.CreatedByName ?? "-")</small></td>
                                    <td>
                                        @if (b.Status == BroadcastStatus.Scheduled || b.Status == BroadcastStatus.Pending)
                                        {
                                            <form method="post" asp-page-handler="Cancel" asp-route-id="@b.Id"
                                                  onsubmit="return confirm('Cancel this broadcast? Pending messages will not be sent.');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
