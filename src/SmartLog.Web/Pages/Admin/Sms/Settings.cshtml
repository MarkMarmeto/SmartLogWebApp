@page
@model SmartLog.Web.Pages.Admin.Sms.SettingsModel
@{
    ViewData["Title"] = "SMS Settings";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-gear me-2"></i>SMS Settings</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post">
        <!-- General Settings -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-sliders me-2"></i>General Settings
            </div>
            <div class="card-body">
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="smsEnabled"
                           name="SmsEnabled" value="true" checked="@(Model.SmsEnabled ? "checked" : null)" />
                    <label class="form-check-label" for="smsEnabled">
                        <strong>Enable SMS Notifications</strong>
                    </label>
                    <input type="hidden" name="SmsEnabled" value="false" />
                    <div class="form-text">Turn SMS notifications on or off globally</div>
                </div>

                <div class="mb-3">
                    <label for="defaultProvider" class="form-label">Default Provider</label>
                    <select class="form-select" id="defaultProvider" name="DefaultProvider">
                        <option value="GSM_MODEM" selected="@(Model.DefaultProvider == "GSM_MODEM" ? "selected" : null)">GSM Modem (Offline)</option>
                        <option value="SEMAPHORE" selected="@(Model.DefaultProvider == "SEMAPHORE" ? "selected" : null)">Semaphore (Cloud)</option>
                    </select>
                    <div class="form-text">Primary SMS gateway to use</div>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="fallbackEnabled"
                           name="FallbackEnabled" value="true" checked="@(Model.FallbackEnabled ? "checked" : null)" />
                    <label class="form-check-label" for="fallbackEnabled">
                        Enable Fallback Provider
                    </label>
                    <input type="hidden" name="FallbackEnabled" value="false" />
                    <div class="form-text">Automatically use alternate provider if primary fails</div>
                </div>
            </div>
        </div>

        <!-- GSM Modem Settings -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-phone me-2"></i>GSM Modem Settings
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="gsmPortName" class="form-label">Serial Port</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="gsmPortName"
                                   name="GsmPortName" value="@Model.GsmPortName" />
                            <button type="button" class="btn btn-outline-secondary" onclick="detectPorts()">
                                <i class="bi bi-search me-1"></i>Detect
                            </button>
                        </div>
                        @if (Model.AvailablePorts.Any())
                        {
                            <div class="form-text">
                                Detected ports:
                                @foreach (var port in Model.AvailablePorts)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary ms-1"
                                            onclick="document.getElementById('gsmPortName').value='@port'">@port</button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="form-text text-warning">No serial ports detected. Plug in your GSM modem and click Detect.</div>
                        }
                        <div id="portDetectionResult" class="form-text" style="display:none;"></div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="gsmBaudRate" class="form-label">Baud Rate</label>
                        <select class="form-select" id="gsmBaudRate" name="GsmBaudRate">
                            <option value="9600" selected="@(Model.GsmBaudRate == 9600 ? "selected" : null)">9600</option>
                            <option value="19200" selected="@(Model.GsmBaudRate == 19200 ? "selected" : null)">19200</option>
                            <option value="38400" selected="@(Model.GsmBaudRate == 38400 ? "selected" : null)">38400</option>
                            <option value="57600" selected="@(Model.GsmBaudRate == 57600 ? "selected" : null)">57600</option>
                            <option value="115200" selected="@(Model.GsmBaudRate == 115200 ? "selected" : null)">115200</option>
                        </select>
                        <div class="form-text">Serial communication speed</div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="gsmSendDelay" class="form-label">Send Delay (ms)</label>
                        <input type="number" class="form-control" id="gsmSendDelay"
                               name="GsmSendDelay" value="@Model.GsmSendDelay" min="1000" max="10000" />
                        <div class="form-text">Delay between messages (recommended: 3000ms)</div>
                    </div>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>GSM Modem Status:</strong>
                    @if (Model.GsmHealth.IsHealthy)
                    {
                        <span class="badge bg-success">Online</span>
                        <span class="ms-2">@Model.GsmHealth.Status</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Offline</span>
                        <span class="ms-2">@Model.GsmHealth.Status</span>
                    }
                    @if (Model.GsmHealth.Details.Any())
                    {
                        <ul class="mt-2 mb-0">
                            @foreach (var detail in Model.GsmHealth.Details)
                            {
                                <li>@detail.Key: <strong>@detail.Value</strong></li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Semaphore Settings -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <i class="bi bi-cloud me-2"></i>Semaphore Cloud Settings
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="semaphoreApiKey" class="form-label">API Key</label>
                        <input type="password" class="form-control" id="semaphoreApiKey"
                               name="SemaphoreApiKey" value="@Model.SemaphoreApiKey" />
                        <div class="form-text">Get your API key from semaphore.co</div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="semaphoreSenderName" class="form-label">Sender Name</label>
                        <input type="text" class="form-control" id="semaphoreSenderName"
                               name="SemaphoreSenderName" value="@Model.SemaphoreSenderName" maxlength="11" />
                        <div class="form-text">Sender ID (max 11 characters)</div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 mb-2">
                    <button type="button" class="btn btn-outline-info btn-sm" onclick="checkSemaphoreStatus(this)">
                        <i class="bi bi-arrow-clockwise me-1"></i>Check Semaphore Status
                    </button>
                    <small class="text-muted" id="semaphoreCheckedAt"></small>
                </div>
                <div id="semaphoreStatusResult" style="display:none;"></div>
            </div>
        </div>

        <!-- Queue Settings -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-list-ul me-2"></i>Queue Settings
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="maxRetries" class="form-label">Max Retries</label>
                        <input type="number" class="form-control" id="maxRetries"
                               name="MaxRetries" value="@Model.MaxRetries" min="1" max="10" />
                        <div class="form-text">Number of retry attempts for failed messages</div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="pollingInterval" class="form-label">Polling Interval (seconds)</label>
                        <input type="number" class="form-control" id="pollingInterval"
                               name="PollingInterval" value="@Model.PollingInterval" min="1" max="60" />
                        <div class="form-text">How often to check for pending messages</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Save Settings
            </button>
            <button type="submit" asp-page-handler="TestConnection" class="btn btn-outline-secondary">
                <i class="bi bi-check-circle me-1"></i>Test Connection
            </button>
        </div>
    </form>

    <!-- Direct Send Test -->
    <div class="card mt-4 mb-4">
        <div class="card-header bg-warning text-dark">
            <i class="bi bi-send-check me-2"></i>Direct Send Test
        </div>
        <div class="card-body">
            <p class="text-muted">Send a real SMS directly through the gateway to verify it works end-to-end. This bypasses the queue and gives instant feedback.</p>
            <form method="post" asp-page-handler="SendTestSms"
                  onsubmit="return confirm('Send a test SMS to this number? This will use real SMS credits.');">
                <input type="hidden" name="DefaultProvider" value="@Model.DefaultProvider" />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="testPhoneNumber" class="form-label">Phone Number</label>
                        <input type="tel" class="form-control" id="testPhoneNumber"
                               name="TestPhoneNumber" placeholder="e.g. 09171234567" required maxlength="20" />
                        <div class="form-text">Enter your own number to receive the test SMS</div>
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-send me-1"></i>Send Test SMS via @Model.DefaultProvider
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function checkSemaphoreStatus(btn) {
            const resultDiv = document.getElementById('semaphoreStatusResult');
            const checkedAtEl = document.getElementById('semaphoreCheckedAt');

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Checking...';
            resultDiv.style.display = 'none';

            fetch('?handler=SemaphoreStatus')
                .then(r => r.json())
                .then(data => {
                    const badgeClass = data.isHealthy ? 'bg-success' : 'bg-danger';
                    const alertClass = data.isHealthy ? 'alert-success' : 'alert-danger';

                    let detailsHtml = '';
                    if (data.details && Object.keys(data.details).length > 0) {
                        detailsHtml = '<ul class="mt-2 mb-0">';
                        for (const [key, value] of Object.entries(data.details)) {
                            detailsHtml += `<li>${key}: <strong>${value}</strong></li>`;
                        }
                        detailsHtml += '</ul>';
                    }

                    resultDiv.className = `alert ${alertClass}`;
                    resultDiv.innerHTML = `
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Semaphore Status:</strong>
                        <span class="badge ${badgeClass} ms-1">${data.isHealthy ? 'Online' : 'Offline'}</span>
                        <span class="ms-2">${data.status}</span>
                        ${detailsHtml}`;
                    resultDiv.style.display = 'block';
                    checkedAtEl.textContent = 'Last checked: ' + data.checkedAt;
                })
                .catch(() => {
                    resultDiv.className = 'alert alert-danger';
                    resultDiv.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>Failed to reach server. Please try again.';
                    resultDiv.style.display = 'block';
                })
                .finally(() => {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Check Semaphore Status';
                });
        }

        function detectPorts() {
            var resultDiv = document.getElementById('portDetectionResult');
            resultDiv.style.display = 'block';
            resultDiv.innerHTML = '<span class="text-muted">Scanning for serial ports...</span>';

            fetch('?handler=DetectPorts')
                .then(r => r.json())
                .then(data => {
                    if (data.error) {
                        resultDiv.innerHTML = '<span class="text-danger">Error: ' + data.error + '</span>';
                        return;
                    }
                    if (data.count === 0) {
                        resultDiv.innerHTML = '<span class="text-warning">No serial ports found. Make sure your GSM modem is plugged in.</span>';
                        return;
                    }
                    var html = '<span class="text-success">Found ' + data.count + ' port(s): </span>';
                    data.ports.forEach(function(port) {
                        html += '<button type="button" class="btn btn-sm btn-outline-success ms-1" ' +
                                'onclick="document.getElementById(\'gsmPortName\').value=\'' + port + '\'">' + port + '</button> ';
                    });
                    resultDiv.innerHTML = html;
                })
                .catch(function() {
                    resultDiv.innerHTML = '<span class="text-danger">Failed to detect ports.</span>';
                });
        }
    </script>
}
