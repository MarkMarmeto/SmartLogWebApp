@page
@model SmartLog.Web.Pages.Admin.Sms.BulkSendModel
@{
    ViewData["Title"] = "Bulk Send SMS";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-people me-2"></i>Bulk Send SMS</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.IsSmsEnabled)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>SMS sending is globally disabled.</strong> Messages will be queued but not sent until SMS is re-enabled in
            <a asp-page="/Admin/Sms/Settings" class="alert-link">Settings</a>.
        </div>
    }

    <form method="post" id="bulkSendForm">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-funnel me-2"></i>Recipient Filters
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Select the programs and grade levels to include. All programs and grades are selected by default.</p>
                <partial name="_ProgramFirstTargeting" model="Model.Targeting" />

                <div class="row mt-3">
                    <div class="col-md-6 mb-3">
                        <label for="selectedSection" class="form-label">Section (Optional)</label>
                        <select class="form-select" id="selectedSection" name="SelectedSection">
                            <option value="">All Sections</option>
                            @foreach (var s in Model.AvailableSections)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="activeOnly" name="ActiveOnly"
                                   value="true" checked />
                            <label class="form-check-label" for="activeOnly">Active students only</label>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info mb-0">
                    <strong>Estimated Recipients:</strong>
                    <span id="recipientCount">@Model.TotalActiveStudents</span> students
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-chat-text me-2"></i>Message
            </div>
            <div class="card-body">
                @{
                    ViewData["MaxLength"] = 320;
                    ViewData["FormId"] = "bulkSendForm";
                    ViewData["ShowSkipHint"] = true;
                }
                <partial name="_MessageBodiesInput" model="Model.MessageBodies" />
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="button" class="btn btn-primary btn-lg" onclick="confirmBulkSend()">
                <i class="bi bi-send me-1"></i>Send Bulk SMS
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/sms-broadcast-targeting.js"></script>
    <script>
        document.getElementById('selectedSection').addEventListener('change', refreshCount);
        document.getElementById('activeOnly').addEventListener('change', refreshCount);

        window.onTargetingChanged = function () { refreshCount(); };

        function refreshCount() {
            var targetingJson = window.getBroadcastTargetingJson();
            var section = document.getElementById('selectedSection').value;
            var activeOnly = document.getElementById('activeOnly').checked;

            var params = new URLSearchParams();
            if (targetingJson && targetingJson !== '[]') params.append('targetingJson', targetingJson);
            if (section) params.append('section', section);
            params.append('activeOnly', activeOnly);

            fetch('?handler=RecipientCount&' + params.toString())
                .then(r => r.json())
                .then(data => { document.getElementById('recipientCount').textContent = data.count; });
        }

        function confirmBulkSend() {
            const count = document.getElementById('recipientCount').textContent;
            if (confirm('Send to ' + count + ' students?')) {
                document.getElementById('bulkSendForm').submit();
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            window.initBroadcastTargeting();
        });
    </script>
}
