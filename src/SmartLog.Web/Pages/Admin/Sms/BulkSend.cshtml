@page
@model SmartLog.Web.Pages.Admin.Sms.BulkSendModel
@{
    ViewData["Title"] = "Bulk Send SMS";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-people me-2"></i>Bulk Send SMS</h1>
        <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" onsubmit="return confirmBulkSend();">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-funnel me-2"></i>Recipient Filters
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Grade Levels</label>
                    <div class="row">
                        @foreach (var grade in Model.AvailableGrades)
                        {
                            <div class="col-md-3 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input grade-checkbox" type="checkbox"
                                           name="SelectedGrades" value="@grade" id="grade_@grade" />
                                    <label class="form-check-label" for="grade_@grade">
                                        Grade @grade
                                        @if (Model.StudentCountByGrade.ContainsKey(grade))
                                        {
                                            <span class="text-muted">(@Model.StudentCountByGrade[grade])</span>
                                        }
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="form-text">Leave unchecked to send to all grade levels</div>
                </div>

                @if (Model.AvailablePrograms.Any())
                {
                    <div class="mb-3">
                        <label class="form-label">Programs</label>
                        <div class="row">
                            @foreach (var prog in Model.AvailablePrograms)
                            {
                                <div class="col-md-3 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input program-checkbox" type="checkbox"
                                               name="SelectedPrograms" value="@prog.Code" id="prog_@prog.Code" />
                                        <label class="form-check-label" for="prog_@prog.Code">
                                            @prog.Code
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="form-text">Leave unchecked to send to all programs</div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="selectedSection" class="form-label">Section (Optional)</label>
                        <select class="form-select" id="selectedSection" name="SelectedSection">
                            <option value="">All Sections</option>
                            @foreach (var s in Model.AvailableSections)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="activeOnly" name="ActiveOnly"
                                   value="true" checked />
                            <label class="form-check-label" for="activeOnly">
                                Active students only
                            </label>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info">
                    <strong>Estimated Recipients:</strong>
                    <span id="recipientCount">@Model.TotalActiveStudents</span> students
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-chat-text me-2"></i>Message
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="message" class="form-label">Message <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="message" name="Message" rows="4"
                              required maxlength="320" placeholder="Enter your message..."></textarea>
                    <div class="form-text">
                        <span id="charCount">0</span> / 320 characters
                    </div>
                </div>

                <div class="mb-3">
                    <label for="preferredProvider" class="form-label">Send via</label>
                    <select class="form-select" id="preferredProvider" name="PreferredProvider">
                        <option value="">System default</option>
                        <option value="SEMAPHORE">Online (Semaphore)</option>
                        <option value="GSM_MODEM">Offline (GSM Modem)</option>
                    </select>
                    <div class="form-text">Override the system default gateway for this broadcast only.</div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-page="/Admin/Sms/Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-send me-1"></i>Send Bulk SMS
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Character counter
        document.getElementById('message').addEventListener('input', function() {
            document.getElementById('charCount').textContent = this.value.length;
        });

        // Update recipient count dynamically
        document.querySelectorAll('.grade-checkbox, .program-checkbox').forEach(cb => cb.addEventListener('change', updateCount));
        document.getElementById('selectedSection').addEventListener('change', updateCount);
        document.getElementById('activeOnly').addEventListener('change', updateCount);

        function updateCount() {
            var grades = Array.from(document.querySelectorAll('.grade-checkbox:checked')).map(cb => cb.value);
            var programs = Array.from(document.querySelectorAll('.program-checkbox:checked')).map(cb => cb.value);
            var section = document.getElementById('selectedSection').value;
            var activeOnly = document.getElementById('activeOnly').checked;

            var params = new URLSearchParams();
            grades.forEach(g => params.append('grades', g));
            programs.forEach(p => params.append('programs', p));
            if (section) params.append('section', section);
            params.append('activeOnly', activeOnly);

            fetch('?handler=RecipientCount&' + params.toString())
                .then(r => r.json())
                .then(data => {
                    document.getElementById('recipientCount').textContent = data.count;
                });
        }

        function confirmBulkSend() {
            var count = document.getElementById('recipientCount').textContent;
            return confirm('Send to ' + count + ' students?');
        }
    </script>
}
