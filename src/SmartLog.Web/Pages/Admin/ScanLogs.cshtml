@page
@model SmartLog.Web.Pages.Admin.ScanLogsModel
@{
    ViewData["Title"] = "Scan Logs";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-qr-code-scan me-2"></i>Scan Logs</h1>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@Model.TotalScans</h3>
                    <p class="text-muted mb-0">Total Scans</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.AcceptedCount</h3>
                    <p class="text-muted mb-0">Accepted</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@Model.RejectedCount</h3>
                    <p class="text-muted mb-0">Rejected</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@Model.DuplicateCount</h3>
                    <p class="text-muted mb-0">Duplicate</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-2">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="">All</option>
                        <option value="ACCEPTED" selected="@(Model.StatusFilter == "ACCEPTED")">Accepted</option>
                        <option value="REJECTED_INVALID_QR" selected="@(Model.StatusFilter == "REJECTED_INVALID_QR")">Rejected - Invalid QR</option>
                        <option value="REJECTED_QR_INVALIDATED" selected="@(Model.StatusFilter == "REJECTED_QR_INVALIDATED")">Rejected - QR Invalidated</option>
                        <option value="REJECTED_STUDENT_INACTIVE" selected="@(Model.StatusFilter == "REJECTED_STUDENT_INACTIVE")">Rejected - Inactive</option>
                        <option value="REJECTED_NOT_SCHOOL_DAY" selected="@(Model.StatusFilter == "REJECTED_NOT_SCHOOL_DAY")">Rejected - Not School Day</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="scanTypeFilter" class="form-label">Type</label>
                    <select class="form-select" id="scanTypeFilter" name="scanTypeFilter">
                        <option value="">All</option>
                        <option value="ENTRY" selected="@(Model.ScanTypeFilter == "ENTRY")">Entry</option>
                        <option value="EXIT" selected="@(Model.ScanTypeFilter == "EXIT")">Exit</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="deviceFilter" class="form-label">Device</label>
                    <select class="form-select" id="deviceFilter" name="deviceFilter">
                        <option value="">All</option>
                        @foreach (var device in Model.Devices)
                        {
                            <option value="@device.Id" selected="@(Model.DeviceFilter == device.Id.ToString())">@device.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="studentSearch" class="form-label">Student</label>
                    <input type="text" class="form-control" id="studentSearch" name="studentSearch"
                           value="@Model.StudentSearch" placeholder="Name or ID..." />
                </div>
                <div class="col-md-2">
                    <label for="startDate" class="form-label">Start Date</label>
                    <input type="date" class="form-control" id="startDate" name="startDate"
                           value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label for="endDate" class="form-label">End Date</label>
                    <input type="date" class="form-control" id="endDate" name="endDate"
                           value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-12 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-search me-1"></i>Filter
                    </button>
                    <a asp-page="/Admin/ScanLogs" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Scans Table -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-list-check me-2"></i>Scan Records (@Model.TotalScans)
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-sm">
                    <thead>
                        <tr>
                            <th>Scanned At</th>
                            <th>Received At</th>
                            <th>Student ID</th>
                            <th>Student Name</th>
                            <th>Grade</th>
                            <th>Section</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Device</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Scans.Any())
                        {
                            @foreach (var scan in Model.Scans)
                            {
                                <tr class="@(scan.Status.StartsWith("REJECTED") ? "table-danger" : "")">
                                    <td class="text-nowrap">@scan.ScannedAt.ToString("MMM dd hh:mm:ss tt")</td>
                                    <td class="text-nowrap">@scan.ReceivedAt.ToString("MMM dd hh:mm:ss tt")</td>
                                    <td>@scan.StudentId</td>
                                    <td>@scan.StudentName</td>
                                    <td>@scan.GradeLevel</td>
                                    <td>@scan.Section</td>
                                    <td>
                                        @if (scan.ScanType == "ENTRY")
                                        {
                                            <span class="badge bg-success">Entry</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">Exit</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (scan.Status)
                                        {
                                            case "ACCEPTED":
                                                <span class="badge bg-success">Accepted</span>
                                                break;
                                            case "REJECTED_INVALID_QR":
                                                <span class="badge bg-danger">Invalid QR</span>
                                                break;
                                            case "REJECTED_QR_INVALIDATED":
                                                <span class="badge bg-danger">QR Invalidated</span>
                                                break;
                                            case "REJECTED_STUDENT_INACTIVE":
                                                <span class="badge bg-danger">Inactive Student</span>
                                                break;
                                            case "REJECTED_NOT_SCHOOL_DAY":
                                                <span class="badge bg-warning text-dark">Not School Day</span>
                                                break;
                                            case "DUPLICATE":
                                                <span class="badge bg-secondary">Duplicate</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@scan.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td><span class="badge text-dark bg-light border">@scan.DeviceName</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted">No scan records found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/ScanLogs"
                               asp-route-pageNumber="@(Model.PageNumber - 1)"
                               asp-route-statusFilter="@Model.StatusFilter"
                               asp-route-scanTypeFilter="@Model.ScanTypeFilter"
                               asp-route-deviceFilter="@Model.DeviceFilter"
                               asp-route-studentSearch="@Model.StudentSearch"
                               asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                               asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                <a class="page-link" asp-page="/Admin/ScanLogs"
                                   asp-route-pageNumber="@i"
                                   asp-route-statusFilter="@Model.StatusFilter"
                                   asp-route-scanTypeFilter="@Model.ScanTypeFilter"
                                   asp-route-deviceFilter="@Model.DeviceFilter"
                                   asp-route-studentSearch="@Model.StudentSearch"
                                   asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                                   asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="/Admin/ScanLogs"
                               asp-route-pageNumber="@(Model.PageNumber + 1)"
                               asp-route-statusFilter="@Model.StatusFilter"
                               asp-route-scanTypeFilter="@Model.ScanTypeFilter"
                               asp-route-deviceFilter="@Model.DeviceFilter"
                               asp-route-studentSearch="@Model.StudentSearch"
                               asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                               asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")">Next</a>
                        </li>
                    </ul>
                </nav>
                <p class="text-center text-muted mt-2">
                    Page @Model.PageNumber of @Model.TotalPages
                </p>
            </div>
        }
    </div>
</div>
