@page
@model SmartLog.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card shadow">
            <div class="card-body p-5">
                <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                <h2 class="mt-3">An error occurred</h2>
                <p class="text-muted">Sorry, something went wrong processing your request.</p>

                @if (Model.ShowRequestId)
                {
                    <p class="small"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
                }

                <a asp-page="/Index" class="btn btn-primary mt-3">
                    <i class="bi bi-house me-2"></i>Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
