# SmartLog Environment Variables
# Copy this file to .env and fill in the values

# Database connection string (REQUIRED in production)
SMARTLOG_DB_CONNECTION=Server=localhost,1433;Database=SmartLog;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=false

# HMAC secret key for QR code signing (REQUIRED in production)
# Generate with: openssl rand -base64 32
SMARTLOG_HMAC_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_KEY

# Seed password for initial admin accounts (REQUIRED in production)
# Must meet password policy: 8+ chars, uppercase, lowercase, digit, special char
SMARTLOG_SEED_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# CORS allowed origins (comma-separated, optional)
# Cors__AllowedOrigins__0=https://your-scanner-device.local

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production
